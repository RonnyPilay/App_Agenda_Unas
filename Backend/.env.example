# Copia este archivo a .env y completa los valores reales antes de ejecutar el backend
PORT=4000
DATABASE_URL=postgresql://<usuario>:<password>@<host>/<database>?sslmode=require
# Sólo si usas el proxy de Neon vía WebSocket, agrega NEON_DATABASE_URL
# NEON_DATABASE_URL=postgresql://<usuario>:<password>@<host>/<database>
